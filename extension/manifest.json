{
  "manifest_version": 3,
  "name": "Utkal IT Dashboard Scraper",
  "version": "1.0",
  "description": "Scrapes IT dashboard metrics securely inside Edge and forwards them to the local dashboard UI.",
  "permissions": ["storage", "alarms", "tabs", "activeTab"],
  "host_permissions": [
    "*://10.36.91.45/*",
    "*://10.36.91.46/*",
    "*://10.23.50.27/*",
    "*://hsd.adityabirla.com/*",
    "*://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://hsd.adityabirla.com/*"],
      "js": ["content_symphony.js"]
    },
    {
      "matches": ["*://10.36.91.45/*", "*://10.36.91.46/*"],
      "js": ["content_solarwinds.js"]
    },
    {
      "matches": ["*://10.23.50.27/*"],
      "js": ["content_nutanix.js"]
    }
  ]
}
